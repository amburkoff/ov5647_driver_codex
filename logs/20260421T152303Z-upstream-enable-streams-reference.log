633-static int ov5647_power_off(struct device *dev)
634-{
635-	struct ov5647 *sensor = dev_get_drvdata(dev);
636-	int ret;
637-
638-	dev_dbg(dev, "OV5647 power off\n");
639-
640-	ret = regmap_multi_reg_write(sensor->regmap, sensor_oe_disable_regs,
641-				     ARRAY_SIZE(sensor_oe_disable_regs));
642-	if (ret < 0)
643-		dev_dbg(dev, "disable oe failed\n");
644-
645-	/* Enter software standby */
646-	ret = cci_update_bits(sensor->regmap, OV5647_SW_STANDBY, 0x01, 0x00, NULL);
647-	if (ret < 0)
648-		dev_dbg(dev, "software standby failed\n");
649-
650-	clk_disable_unprepare(sensor->xclk);
651-	gpiod_set_value_cansleep(sensor->pwdn, 1);
652-	regulator_bulk_disable(OV5647_NUM_SUPPLIES, sensor->supplies);
653-
654-	return 0;
655-}
