467-static int ov5647_write16(struct v4l2_subdev *sd, u16 reg, u16 val)
468-{
469-	unsigned char data[4] = { reg >> 8, reg & 0xff, val >> 8, val & 0xff};
470-	struct i2c_client *client = v4l2_get_subdevdata(sd);
471-	int ret;
472-
473-	ret = i2c_master_send(client, data, 4);
474-	/*
475-	 * Writing the wrong number of bytes also needs to be flagged as an
476-	 * error. Success needs to produce a 0 return code.
477-	 */
478-	if (ret == 4) {
479-		ret = 0;
480-	} else {
481-		dev_dbg(&client->dev, "%s: i2c write error, reg: %x\n",
482-			__func__, reg);
483-		return ret;
484-	}
485-
486-	return 0;
487-}
