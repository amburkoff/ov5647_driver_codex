+		"nvidia,p3768-0000+p3767-0000",
+		"nvidia,p3768-0000+p3767-0001",
+		"nvidia,p3768-0000+p3767-0003",
+		"nvidia,p3768-0000+p3767-0004",
+		"nvidia,p3768-0000+p3767-0005";
+
+	/*
+	 * Controlled software-only branch derived from the reviewed external
+	 * Orin NX/P3768 sample:
+	 *
+	 * - route C / serial_c / port-index 2 / 2 lanes
+	 * - reset-only semantics on GPIO token 0xa0
+	 * - no pwdn-gpios
+	 * - mclk_khz = 25000
+	 * - discontinuous_clk = "yes"
+	 * - cil_settletime = "0"
+	 *
+	 * This is intentionally separate from the route-A work. It tests whether
+	 * the current setup is closer to the shared route-C sample than to the
+	 * route-A p3768 references we have tried so far.
+	 */
+
+	fragment@0 {
+		target-path = "/";
+
+		__overlay__ {
+			tegra-capture-vi {
+				num-channels = <1>;
+
+				ports {
+					#address-cells = <1>;
+					#size-cells = <0>;
+
+					port@1 {
+						reg = <0>;
+
+						ov5647_probe_c_rst25_vi_in0: endpoint {
+							port-index = <2>;
+							bus-width = <2>;
+							remote-endpoint = <&ov5647_probe_c_rst25_csi_out0>;
+						};
+					};
+				};
+			};
+
+			tegra-camera-platform {
+				compatible = "nvidia, tegra-camera-platform";
+
+				modules {
