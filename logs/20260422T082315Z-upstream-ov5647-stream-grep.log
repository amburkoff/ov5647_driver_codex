552:		       MIPI_CTRL00_LINE_SYNC_ENABLE;
554:	cci_write(sensor->regmap, OV5647_REG_MIPI_CTRL00, val, &ret);
573:	ret = ov5647_stream_stop(sensor);
615:	ret = ov5647_stream_stop(sensor);
