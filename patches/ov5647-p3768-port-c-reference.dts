/dts-v1/;
/plugin/;

/ {
	overlay-name = "OV5647 reference route C reset-only for p3768/p3767";
	jetson-header-name = "Jetson 22pin CSI Connector";
	compatible =
		"nvidia,p3768-0000+p3767-0000",
		"nvidia,p3768-0000+p3767-0001",
		"nvidia,p3768-0000+p3767-0003",
		"nvidia,p3768-0000+p3767-0004",
		"nvidia,p3768-0000+p3767-0005";

	/*
	 * Current software-most-correct reference branch for further comparison:
	 *
	 * - route C / serial_c / port-index 2 / 2 lanes
	 * - reset-only semantics on GPIO token 0xa0
	 * - no pwdn-gpios
	 * - mclk_khz = 25000 in DT, matching the reviewed external Orin NX sample
	 * - discontinuous_clk = "yes"
	 * - cil_settletime = "0"
	 *
	 * This is not declared electrically proven. It is the repository's
	 * baseline "best software guess" after route-A, route-C, lane-polarity,
	 * PWDN, test-pattern, and settle-time experiments.
	 */

	fragment@0 {
		target-path = "/";

		__overlay__ {
			tegra-capture-vi {
				num-channels = <1>;

				ports {
					#address-cells = <1>;
					#size-cells = <0>;

					port@1 {
						reg = <0>;

						ov5647_ref_c_vi_in0: endpoint {
							port-index = <2>;
							bus-width = <2>;
							remote-endpoint = <&ov5647_ref_c_csi_out0>;
						};
					};
				};
			};

			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";

				modules {
					module1 {
						badge = "ov5647_reference_route_c";
						position = "rear";
						orientation = "1";

						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree =
								"/sys/firmware/devicetree/base/bus@0/cam_i2cmux/i2c@1/ov5647_c@36";
						};
					};
				};
			};

			bus@0 {
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <1>;
						#address-cells = <1>;
						#size-cells = <0>;

						channel@1 {
							reg = <0>;

							ports {
								#address-cells = <1>;
								#size-cells = <0>;

								port@0 {
									reg = <0>;

									ov5647_ref_c_csi_in0: endpoint@2 {
										port-index = <2>;
										bus-width = <2>;
										remote-endpoint = <&ov5647_ref_c_out0>;
									};
								};

								port@1 {
									reg = <1>;

									ov5647_ref_c_csi_out0: endpoint@3 {
										remote-endpoint = <&ov5647_ref_c_vi_in0>;
									};
								};
							};
						};
					};
				};

				cam_i2cmux {
					status = "okay";
					compatible = "i2c-mux-gpio";
					#address-cells = <1>;
					#size-cells = <0>;
					mux-gpios = <&gpio_aon 19 0>;
					i2c-parent = <&cam_i2c>;

					i2c@0 {
						status = "okay";
						reg = <0>;
						#address-cells = <1>;
						#size-cells = <0>;

						ov5647_a@36 {
							reg = <0x36>;
							status = "disabled";
						};
					};

					i2c@1 {
						status = "okay";
						reg = <1>;
						#address-cells = <1>;
						#size-cells = <0>;

						ov5647_c@36 {
							status = "okay";
							compatible = "ovti,ov5647";
							reg = <0x36>;
							devnode = "video0";
							physical_w = "3.680";
							physical_h = "2.760";
							sensor_model = "ov5647";
							use_sensor_mode_id = "true";
							mclk = "extperiph1";
							clocks = <&bpmp 0x24>;
							clock-names = "extperiph1";
							avdd-reg = "vana";
							dvdd-reg = "vdig";
							iovdd-reg = "vif";
							reset-gpios = <&gpio 0xa0 0>;

							mode0 {
								mclk_khz = "25000";
								num_lanes = "2";
								tegra_sinterface = "serial_c";
								lane_polarity = "0";
								phy_mode = "DPHY";
								discontinuous_clk = "yes";
								dpcm_enable = "false";
								cil_settletime = "0";
								active_w = "640";
								active_h = "480";
								mode_type = "bayer";
								pixel_phase = "bggr";
								csi_pixel_bit_depth = "10";
								readout_orientation = "90";
								line_length = "1852";
								inherent_gain = "1";
								mclk_multiplier = "2.33";
								pix_clk_hz = "58333000";
								gain_factor = "16";
								framerate_factor = "1000000";
								exposure_factor = "1000000";
								min_gain_val = "16";
								max_gain_val = "1023";
								step_gain_val = "1";
								default_gain = "32";
								min_hdr_ratio = "1";
								max_hdr_ratio = "1";
								min_framerate = "1000000";
								max_framerate = "60000000";
								step_framerate = "1";
								default_framerate = "60000000";
								min_exp_time = "4";
								max_exp_time = "500000";
								step_exp_time = "1";
								default_exp_time = "1000";
								embedded_metadata_height = "0";
							};

							ports {
								#address-cells = <1>;
								#size-cells = <0>;

								port@0 {
									reg = <0>;

									ov5647_ref_c_out0: endpoint {
										port-index = <2>;
										bus-width = <2>;
										remote-endpoint = <&ov5647_ref_c_csi_in0>;
									};
								};
							};
						};
					};
				};
			};
		};
	};
};
